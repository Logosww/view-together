{
  "name": "view-together",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "trap 'kill 0' EXIT; bun --bun next dev --turbopack & bun run server/ws.ts & wait",
    "dev:next": "bun --bun next dev",
    "dev:ws": "bun run server/ws.ts",
    "build:ws": "bun build server/ws.ts --outfile dist/ws/server.js --target bun --minify",
    "start:ws": "bun dist/ws/server.js",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "bun --bun oxlint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/eden": "^1.4.9",
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elysia": "^1.4.29",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260705.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "prisma": "^7.8.0",
    "prismabox": "^1.1.26",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  }
